# IRIS — Environment Configuration // JASRAJ
# All keys are optional. Missing keys return mock data — IRIS never crashes.

# AI Providers (free tier)
GEMINI_API_KEY=
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Web / Search
TAVILY_API_KEY=

# Gmail OAuth (create at console.cloud.google.com)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8080/oauth2callback

# ADB (optional remote device)
ADB_HOST=127.0.0.1
ADB_PORT=5037

# Supabase sync (optional). Local state is canonical — missing vars disable sync.
# Tables expected: chat_messages, face_descriptor, pin_hash, settings.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
